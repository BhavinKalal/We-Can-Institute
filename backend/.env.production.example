APP_NAME=WE CAN Institute API
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password
SUPER_ADMIN_FULL_NAME=Super Admin
ADMIN_TOKEN_EXP_MINUTES=720
DATABASE_URL=sqlite:////app/backend/data/wecan.db
DB_ECHO=false
MEDIA_ROOT=/app/backend/media
MEDIA_URL_PATH=/media
BACKEND_CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com
